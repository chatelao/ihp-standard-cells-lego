@startuml
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false

title IHP Standard Cells LEGO Generation Workflow

package "Data Sources" {
    [sg13g2_stdcell.lef] as LEF
    [sg13g2_stdcell.celllist] as List
    folder "/cells/*.cif" as CIFs
    [handmade/*.md] as Handmade
}

package "Orchestration" {
    [generate_all_models.py] as GenAll
}

package "Processing Scripts" {
    [1. cif_to_ldr.py] as CIF2LDR
    [2. generate_design_docs.py] as GenDocs
    [3. design_to_ldr.py] as Design2LDR
    [3.5 generate_construction_images.py] as GenConst
    [3.6 generate_top_images.py] as GenTop
    [4. render_models.sh] as Render
    [5. generate_gallery.py] as GenGallery
}

package "Intermediate Results" {
    folder "/models/*.ldr" as LDRs
    folder "/design/*.md" as Docs
}

package "Final Outputs" {
    folder "/images/*.jpg (Perspective)" as ImagesJpg
    folder "/images/*.png (Top, Side, Compare)" as ImagesPng
    folder "/instructions/*.pdf" as PDFs
    [index.html] as Gallery
}

package "Verification" {
    [6. verify_models_v3.py] as V3
    [6. verify_top_view.py] as TopView
    [6. verify_macro_dimensions.py] as Dim
    [6. verify_pin_existence.py] as Pins
    folder "/logs/*.log" as Logs
}

CIFs --> CIF2LDR
List --> CIF2LDR
CIF2LDR --> LDRs

LDRs --> GenDocs
Handmade --> GenDocs
GenDocs --> Docs

Docs --> Design2LDR
Design2LDR --> LDRs

LDRs --> GenConst
GenConst --> ImagesPng

LDRs --> GenTop
GenTop --> ImagesPng

LDRs --> Render
Render --> ImagesJpg
Render --> PDFs

ImagesJpg --> GenGallery
ImagesPng --> GenGallery
Gallery <.. GenGallery

GenAll ..> CIF2LDR : triggers
GenAll ..> GenDocs : triggers
GenAll ..> Design2LDR : triggers
GenAll ..> GenConst : triggers
GenAll ..> GenTop : triggers
GenAll ..> GenGallery : triggers

LDRs --> V3
LDRs --> TopView
LDRs --> Dim
LDRs --> Pins

V3 --> Logs
TopView --> Logs
Dim --> Logs
Pins --> Logs

@enduml
